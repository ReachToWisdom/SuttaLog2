[
  "\"Dveme, bhikkhave, antā pabbajitena na sevitabbā.\"",
  "Ahaṃ dhammaṃ jānāmi.\\nTvaṃ dhammaṃ jānāsi.",
  "Ahaṃ dhammaṃ suṇāmi.\\nMayaṃ dhammaṃ suṇāma.",
  "Ahaṃ dānaṃ adaṃ.\\nMayaṃ dānaṃ adamhā.",
  "Ahaṃ gāmaṃ gamissāmi.\\nMayaṃ gāmaṃ gamissāma.",
  "Ammā dārikaṃ poseti.\\nAmmāyo dārikāyo posenti.",
  "Bhagavantu",
  "Bhagavatā desitaṃ dhammaṃ\\ndhāremi.",
  "Bhagavā evaṃ avoca",
  "Bhikkhave Tathāgatassa sāvakā honti",
  "Bhikkhavo Tathāgatassa sāvakā honti",
  "Bhikkhu, dhammaṃ suṇāhi!\\nBhikkhave, dhammaṃ suṇātha!",
  "Bhikkhū piṇḍāya carantā gāmaṃ pavisanti.",
  "Brāhmaṇo mātulaṃ rakkhati / Brāhmaṇā mātule rakkhanti",
  "Buddha",
  "Buddhaṃ disvā vandāmi",
  "Buddhaṃ saraṇaṃ gacchāmi",
  "Buddhaṃ saraṇaṃ gacchāmi. Dhammaṃ saraṇaṃ gacchāmi. Saṅghaṃ saraṇaṃ gacchāmi.",
  "Buddhaṃ saraṇaṃ gacchāmi.\\nDhammaṃ saraṇaṃ gacchāmi.\\nSaṅghaṃ saraṇaṃ gacchāmi.",
  "Buddhaṃ saraṇaṃ gacchāmi\\nDhammaṃ saraṇaṃ gacchāmi\\nSaṅghaṃ saraṇaṃ gacchāmi",
  "Buddhena bhāsitaṃ dhammaṃ suṇāma",
  "Buddhena bhāsitaṃ dhammaṃ suṇāma.",
  "Buddho",
  "Buddho Sāvatthiyaṃ dhammaṃ desesi.\\nBhikkhū dhammaṃ suṇiṃsu.",
  "Buddho dhammaṃ desessati",
  "Buddho dhammaṃ desessati.\\nBuddhā dhammaṃ desessanti.",
  "Buddho dhammaṃ deseti",
  "Buddho dhammaṃ deseti.\\nBhikkhū dhammaṃ suṇanti.",
  "Buddho pūjanīyo sabbalokaṃ.",
  "Cakkhuṃ aniccaṃ, cakkhuṃ anattā",
  "Cakkhuṃ bhikkhave anattā.\\nYadanattā taṃ netaṃ mama,\\nnesohamasmi, na meso attāti.",
  "Caratha bhikkhave cārikaṃ bahujanahitāya",
  "Cattasso imā bhikkhave parisā",
  "Corena dinnaṃ dhanaṃ na gaṇhāmi.",
  "Coro purisaṃ dhanaṃ corāpeti.",
  "Dhammo samaṇena desitabbo.",
  "Dhīvaro narāya macchaṃ āharati.\\nDhīvarā narānaṃ macche āharanti.",
  "Dveme bhikkhave antā pabbajitena na sevitabbā",
  "Dānaṃ dadāmānā sagge uppajjanti",
  "Dānaṃ dadāmānā sīlāni rakkhamānā\\nmanussā sagge uppajjanti.",
  "Dānaṃ dadātu so.\\nDānaṃ dadantu te.",
  "Dārako bhattaṃ bhuñjituṃ icchati.",
  "Dārako bhattaṃ yācitvā rodati.",
  "Ekaṃ",
  "Ekaṃ samayaṃ bhagavā bārāṇasiyaṃ viharati",
  "Ekaṃ samayaṃ bhagavā bārāṇasiyaṃ viharati isipatane migadāye",
  "Ekaṃ samayaṃ bhagavā bārāṇasiyaṃ viharati isipatane migadāye.",
  "Ete kho bhikkhave ubho ante anupagamma majjhimā paṭipadā tathāgatena abhisambuddhā",
  "Evaṃ me sutaṃ: ekaṃ samayaṃ Bhagavā Sāvatthiyaṃ viharati",
  "Evaṃ me sutaṃ:\\nekaṃ samayaṃ Bhagavā\\nSāvatthiyaṃ viharati\\nJetavane Anāthapiṇḍikassa ārāme.",
  "Gacchantī kumārī vihāraṃ passati.",
  "Gato so puriso nagaraṃ.",
  "Hasantiyā kumāriyā saddo suyyati.",
  "Hatā pāpakā dhammā.",
  "Idaṃ kho pana, bhikkhave,\\ndukkhaṃ ariyasaccaṃ—",
  "Karaṇīyaṃ kusalaṃ sukhāvahaṃ",
  "Karaṇīyaṃ kusalaṃ sukhāvahaṃ.",
  "Kassakassa sūkaro dīpaṃ dhāvati.\\nKassakānaṃ sūkarā dīpe dhāvanti.",
  "Kassako kakacena rukkhaṃ chindati.\\nKassakā kakacehi rukkhe chindanti.",
  "Kassako kasati / Kassakā kasanti",
  "Kassako khettamhā āgantvā bhattaṃ bhuñjati.",
  "Kassako nagaraṃ gantuṃ ussahati.",
  "Kassako rukkhasmā patati.\\nKassakā rukkhehi patanti.",
  "Kaññā saddhāya Buddhaṃ namassati.",
  "Kumāra, pupphaṃ āhara!\\nKumārā, pupphāni āharatha!",
  "Kumāro udakaṃ pātuṃ nadiṃ gacchati.",
  "Magge gacchanto naro rukkhaṃ passati.",
  "Manusso kusalañ ca pāpañ ca jānāti.",
  "Muni araññe viharati",
  "Mā pāpaṃ karohi!\\nMā pāpāni karotha!",
  "Mātulassa sahāyako rathaṃ āharati.\\nMātulānaṃ sahāyakā rathe āharanti.",
  "Mātulo pacati / Mātulā pacanti",
  "Mātā dāsiṃ odanaṃ pāceti.",
  "Nadiyā jalaṃ pibanti gāviyo",
  "Namo",
  "Namo tassa bhagavato arahato sammāsambuddhassa",
  "Namo tassa bhagavato arahato sammāsambuddhassa.",
  "Narassa putto bhattaṃ yācati.\\nNarānaṃ puttā bhattaṃ yācanti.",
  "Naro bhāsati / Narā bhāsanti",
  "Nisinnā bhikkhū dhammaṃ suṇanti.",
  "Nāviko samudde tarati.\\nNāvikā samuddesu taranti.",
  "Pacantiyo nāriyo gehesu vasanti.",
  "Pacantī nārī gehasmiṃ vasati",
  "Pacantī nārī gehasmiṃ vasati.",
  "Pitā puttaṃ dānaṃ dāpeti.",
  "Purisa, dānaṃ dehi!\\nPurisā, dānāni detha!",
  "Putto mātulamhā pañhaṃ pucchati.\\nPuttā mātulehi pañhe pucchanti.",
  "Putto mātulassa odanaṃ dadāti.\\nPuttā mātulānaṃ odanaṃ dadanti.",
  "Putto mātulena saha candaṃ passati.\\nPuttā mātulehi saha candaṃ passanti.",
  "Putto naraṃ passati / Puttā nare passanti",
  "Rājā purise kammaṃ kāreti",
  "Rājā purise kammaṃ kāreti.",
  "Rūpaṃ aniccaṃ.\\nRūpāni aniccāni.",
  "Rūpaṃ bhikkhave anattā",
  "Sace samaṇo dhammaṃ deseyya, manussā suṇeyyuṃ.\\nYadi samaṇā dhammaṃ deseyyuṃ, manussā suṇeyyuṃ.",
  "Sace sīlaṃ rakkheyya sukhī assa",
  "Sace tvaṃ sīlaṃ rakkheyyāsi, sukhaṃ labheyyāsi.\\nSace tumhe sīlaṃ rakkheyyātha, sukhaṃ labheyyātha.",
  "Sakuṇo ākāse uppatati.\\nSakuṇā ākāsesu uppatanti.",
  "Samaṇo Buddhaṃ passitvā vandati.",
  "Samaṇo dhammaṃ desetuṃ vihāraṃ gacchati.",
  "Samaṇo narena saddhiṃ gāmaṃ gacchati.\\nSamaṇā narehi saddhiṃ gāmaṃ gacchanti.",
  "Sappuriso loke jīvati.\\nSappurisā lokesu jīvanti.",
  "Satthā bhikkhūnaṃ dhammaṃ desento anukampaṃ upādāya",
  "Satthā bhikkhūnaṃ dhammaṃ desesi",
  "Seyyathāpi bhikkhave puriso\\nAddasā kho Bhagavā āyasmantaṃ\\nĀnandaṃ dūrato va āgacchantaṃ,\\ndisvā āyasmantaṃ Ānandaṃ etad avoca.",
  "Seṭṭhī dāsaṃ bhaṇḍāni kiṇāpeti.",
  "Sugato",
  "Tathāgato",
  "Tiṇṇo samuddaṃ paṇḍito.",
  "Tvaṃ dānaṃ dassasi.\\nTumhe dānaṃ dassatha.",
  "Tvaṃ kiṃ passasi?\\nAhaṃ rukkhaṃ passāmi.",
  "Upāsako bhikkhū bhojeti.",
  "Upāsako dānaṃ dadeyya.\\nUpāsakā dānāni dadeyyuṃ.",
  "Upāsako vihāraṃ agami.\\nUpāsakā vihāraṃ agamiṃsu.",
  "Upāsakā pupphehi Buddhaṃ pūjenti.",
  "Vanitā sālaṃ gacchati.\\nVanitāyo sālaṃ gacchanti.",
  "Vānarā rukkhaṃ āruyha phalāni khādanti.",
  "Vāṇijo kassakassa ajaṃ dadāti.\\nVāṇijā kassakānaṃ aje dadanti.",
  "Vāṇijo kassakaṃ paharati / Vāṇijā kassake paharanti",
  "Yathā Bhagavā dhammaṃ deseti tathā paṭipajjatha",
  "Yathā Bhagavā dhammaṃ deseti,\\ntathā tumhehi paṭipajjitabbaṃ.",
  "Yācako naramhā bhattaṃ yācati.\\nYācakā narehi bhattaṃ yācanti.",
